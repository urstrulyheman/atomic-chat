APP_NAME=OrcaChatCoin
ENV=development
AUTO_CREATE_TABLES=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/orca_chat
REDIS_URL=redis://localhost:6379/0
READINESS_CHECK_REDIS=false
ACCESS_LOG_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000

JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
RAZORPAY_WEBHOOK_MAX_BYTES=65536
ENABLE_DEV_PAYMENT_CAPTURE=true
ENABLE_PUBLIC_USER_DIRECTORY=true
ENABLE_DEV_USER_SEED=true

MESSAGE_DEFAULT_COST=1.0
MESSAGE_RECEIVER_REWARD=0.65
MESSAGE_PLATFORM_GAS=0.25
MESSAGE_RESERVE_REWARD=0.10
MESSAGE_BILLING_TOKENS_PER_UNIT=20
MESSAGE_RECEIVER_REWARD_PERCENT=0.65
MESSAGE_PLATFORM_GAS_PERCENT=0.25
MESSAGE_MAX_CONTENT_LENGTH=4000
MESSAGE_IDEMPOTENCY_KEY_MAX_LENGTH=120
MESSAGE_IDEMPOTENCY_KEY_PATTERN=^[A-Za-z0-9._:-]+$

REWARD_LOCK_DAYS=7
NEW_USER_DAILY_REWARD_CAP=25
VERIFIED_USER_DAILY_REWARD_CAP=250
NEW_USER_DAILY_FREE_MESSAGES=20
VERIFIED_USER_DAILY_FREE_MESSAGES=100
PREMIUM_USER_DAILY_FREE_MESSAGES=500
WELCOME_BONUS_COINS=20
OTP_EXPIRE_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_IP_SENDS_PER_HOUR=300
OTP_PROVIDER=dev
OTP_CODE_LENGTH=6
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=ORCACH
